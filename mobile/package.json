{
  "name": "hotmess-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor native shell for HOTMESS iOS/Android",
  "scripts": {
    "sync": "npm run build --prefix .. && npx cap sync",
    "sync:ios": "npm run build --prefix .. && npx cap sync ios",
    "sync:android": "npm run build --prefix .. && npx cap sync android",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android",
    "live:ios": "npx cap run ios --livereload --external",
    "live:android": "npx cap run android --livereload --external"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0"
  }
}
