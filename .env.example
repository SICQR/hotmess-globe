# HOTMESS — example environment variables. Placeholders only. Never commit real secrets.
# Copy to `.env.local` (gitignored) and fill with real values from the Vercel dashboard
# or your local Supabase / Stripe / Shopify / Resend accounts.

# ── Supabase ────────────────────────────────────────────────────────────────
# VITE_*  — shipped to the browser, must be anon/publishable key only.
# SUPABASE_SERVICE_ROLE_KEY — server-side only, bypasses RLS. Never ship to client.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-or-secret-key>

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Shopify headless ────────────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=<shop>.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=<admin-api-token>
SHOPIFY_STOREFRONT_ACCESS_TOKEN=<storefront-api-token>

# ── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=no-reply@hotmessldn.com
SUPPORT_EMAIL=hello@hotmessldn.com

# ── Anthropic / OpenAI (AI stubs) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ── Push notifications ──────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=<b64-url>
VAPID_PRIVATE_KEY=<b64-url>
VAPID_SUBJECT=mailto:support@hotmessldn.com

# ── Cron + auth tokens ──────────────────────────────────────────────────────
CRON_SECRET=<strong-random>
TICKET_QR_SIGNING_SECRET=<strong-random>
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_WEBHOOK_SECRET=<webhook-secret>
WHATSAPP_VERIFY_TOKEN=<verify-token>

# ── Playwright E2E ──────────────────────────────────────────────────────────
TEST_USER_A_EMAIL=e2e.alpha@hotmessldn.com
TEST_USER_A_PASSWORD=<strong-random>
TEST_USER_B_EMAIL=e2e.beta@hotmessldn.com
TEST_USER_B_PASSWORD=<strong-random>

# ── App URLs ────────────────────────────────────────────────────────────────
APP_URL=https://hotmessldn.com
ALLOWED_ORIGIN=https://hotmessldn.com
