############################################
# HOTMESS env example (safe to commit)
#
# Copy to `.env.local` for local dev.
# Never commit real secrets.
############################################

############################################
# Client (Vite) public env vars (VITE_*)
############################################

# Supabase (required for auth/data)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: client error reporting
VITE_SENTRY_DSN=

# Optional feature flags
VITE_XP_PURCHASING_ENABLED=false

############################################
# Serverless (api/*) env vars (server-only)
############################################

# Supabase server env (used by api/* for auth validation + admin jobs)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Routing / Google Maps (optional)
GOOGLE_MAPS_API_KEY=
GOOGLE_ROUTES_DRIVE_TRAFFIC_AWARE=false
ROUTING_DIRECTIONS_STRICT=false

# Cron / ops (recommended)
HEALTH_SECRET=
OUTBOX_CRON_SECRET=
RATE_LIMIT_CLEANUP_SECRET=
EVENT_SCRAPER_CRON_SECRET=

# Tickets / scan (recommended for production)
TICKET_QR_SIGNING_SECRET=
QR_SIGNING_SECRET=

# Shopify (optional)
SHOPIFY_SHOP_DOMAIN=
# Storefront token (public shop GraphQL)
SHOPIFY_API_STOREFRONT_ACCESS_TOKEN=
# Legacy/back-compat name used in some handlers
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_API_VERSION=2024-10
# Branded checkout host (optional)
SHOPIFY_CHECKOUT_DOMAIN=
# Admin token (import/sync utilities)
SHOPIFY_ADMIN_ACCESS_TOKEN=
# Legacy/back-compat name used in some handlers
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_ALLOWED_PRODUCT_HANDLES=
SHOPIFY_WEBHOOK_SECRET=

# SoundCloud (optional)
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URI=
SOUNDCLOUD_SCOPE=
MUSIC_UPLOAD_EMAILS=
# Client-side allowlist (optional; used by some UIs)
VITE_MUSIC_UPLOAD_EMAILS=

# Event scraper (optional)
EVENT_SCRAPER_SOURCES_JSON=
EVENT_SCRAPER_MAX_EVENTS_PER_CITY=15
EVENT_SCRAPER_USE_WEB_SEARCH=false
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional allowlists
ADMIN_EMAIL_ALLOWLIST=
MEMBERSHIPS_ENABLED=false

############################################
# E2E (local only)
############################################

# Used by `npm run test:e2e:auth`
E2E_EMAIL=
E2E_PASSWORD=

# Deterministic seeding for Social smoke tests
E2E_SEED=true
E2E_SEED_LAT=51.5074
E2E_SEED_LNG=-0.1278
E2E_SEED_COUNT=12
E2E_SEED_SPREAD_M=3000

############################################
# Build-time tooling (optional)
############################################

# Sentry sourcemap upload (CI/build only; keep server-side)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=

