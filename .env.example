# HOTMESS — example environment variables. Placeholders only. Never commit real secrets.
# Copy to `.env.local` (gitignored) and fill with real values from the Vercel dashboard
# or your local Supabase / Stripe / Shopify / Resend accounts.

# ── Supabase ────────────────────────────────────────────────────────────────
# VITE_*  — shipped to the browser, must be anon/publishable key only.
# SUPABASE_SERVICE_ROLE_KEY — server-side only, bypasses RLS. Never ship to client.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-or-secret-key>

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Shopify headless ────────────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=<shop>.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=<admin-api-token>
SHOPIFY_STOREFRONT_ACCESS_TOKEN=<storefront-api-token>

# ── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=no-reply@hotmessldn.com
SUPPORT_EMAIL=hello@hotmessldn.com

# ── Anthropic / OpenAI (AI stubs) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ── Push notifications ──────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=<b64-url>
VAPID_PRIVATE_KEY=<b64-url>
VAPID_SUBJECT=mailto:support@hotmessldn.com

# ── Cron + auth tokens ──────────────────────────────────────────────────────
CRON_SECRET=<strong-random>
TICKET_QR_SIGNING_SECRET=<strong-random>
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_WEBHOOK_SECRET=<webhook-secret>
WHATSAPP_VERIFY_TOKEN=<verify-token>

# ── Playwright E2E ──────────────────────────────────────────────────────────
TEST_USER_A_EMAIL=e2e.alpha@hotmessldn.com
TEST_USER_A_PASSWORD=<strong-random>
TEST_USER_B_EMAIL=e2e.beta@hotmessldn.com
TEST_USER_B_PASSWORD=<strong-random>

# ── App URLs ────────────────────────────────────────────────────────────────
APP_URL=https://hotmessldn.com
ALLOWED_ORIGIN=https://hotmessldn.com

# ── WhatsApp / Meta (audit 2026-05-18 — were referenced in code, missing here) ─
WHATSAPP_BUSINESS_ACCOUNT_ID=<waba-id-from-meta-business-suite>
WHATSAPP_PHONE_NUMBER_ID=<phone-number-id-from-meta-business-suite>
WHATSAPP_ACCESS_TOKEN=<long-lived-access-token>
WHATSAPP_TEMPLATE_NAME=safety_alert_v1
RESEND_SAFETY_FROM=HOTMESS Safety <safety@hotmessldn.com>

# ── Telegram (Phil-direct ops alert) ─────────────────────────────────────────
PHIL_TELEGRAM_CHAT_ID=<numeric-chat-id-via-t.me/HotmessAuthBot/start>
PHIL_OPS_PHONE=+447444203409

# ── Radio + safety flags ─────────────────────────────────────────────────────
VITE_AZURACAST_STREAM_URL=https://radio.hotmessldn.com/listen/stream
VITE_SOS_ENABLED=true

# SOS trusted-contact consent grace window (Option B). ISO-8601 absolute cutoff.
# While now < this timestamp, SOS pages consented contacts AND still-pending
# (unconfirmed) contacts. After it passes — or if unset/invalid — only consented
# contacts are paged (fail toward the hard consent gate). GRACE = 14 DAYS: at
# deploy, set this to (deploy time + 14d), e.g. 2026-07-15T00:00:00Z. Do NOT
# commit a literal date to source — it lives here as an env var only.
SOS_CONSENT_GRACE_UNTIL=

# DRAFT stale-event janitor (api/cron/safety-events-stale-close.js). Ships
# DISABLED. Leave UNSET/empty. Only set to 'true' after the safety review in
# that file (it can only ever close acknowledged, week-old, already-unresolved
# events — never a live SOS).
SAFETY_STALE_CLOSE_ENABLED=
SAFETY_STALE_TTL_HOURS=168

# ── Auth feature flags (audit 2026-05-18) ────────────────────────────────────
# Set to 'true' only after the Apple OAuth Services ID + .p8 key are configured
# in Supabase Dashboard → Auth → Providers → Apple. Both src/pages/Auth.jsx
# and src/components/onboarding/screens/SignUpScreen.jsx gate on this.
VITE_AUTH_APPLE_ENABLED=false

# ── Reentry token HMAC (cofounder reentry flow) ──────────────────────────────
REENTRY_SECRET=<32+-char-random-string>
