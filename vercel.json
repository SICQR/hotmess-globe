{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "regions": [
    "lhr1",
    "iad1"
  ],
  "env": {
    "STRIPE_BOOST_GLOBE_GLOW_PRICE_ID": "price_1TSG4FFD4E2lo8AphdaOGmdA",
    "STRIPE_BOOST_PROFILE_BUMP_PRICE_ID": "price_1TSG4JFD4E2lo8ApmEzQHWrg",
    "STRIPE_BOOST_VIBE_BLAST_PRICE_ID": "price_1TSG4MFD4E2lo8ApBKaJsOWy",
    "STRIPE_BOOST_INCOGNITO_PRICE_ID": "price_1TSG4QFD4E2lo8ApWoTaJ8WJ",
    "STRIPE_BOOST_EXTRA_BEACON_PRICE_ID": "price_1TSG4TFD4E2lo8ApStwEZkws",
    "STRIPE_BOOST_HIGHLIGHTED_MSG_PRICE_ID": "price_1TSG4XFD4E2lo8ApZsYrpuxL",
    "CF_ACCOUNT_ID": "set-in-vercel-dashboard",
    "CF_API_TOKEN": "set-in-vercel-dashboard",
    "PHOTODNA_SUBSCRIPTION_KEY": "set-in-vercel-dashboard",
    "REVENUECAT_API_KEY_IOS": "set-in-vercel-dashboard",
    "REVENUECAT_API_KEY_ANDROID": "set-in-vercel-dashboard",
    "REVENUECAT_WEBHOOK_SECRET": "set-in-vercel-dashboard"
  },
  "crons": [
    {
      "path": "/api/events/cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/notifications/process",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/notifications/dispatch",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/safety/check-ins",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/admin/cleanup/rate-limits",
      "schedule": "20 4 * * *"
    },
    {
      "path": "/api/cron/referral-rewards",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/whatsapp/daily-summary",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/support/sync-meetings",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 2 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.hotmessldn.com"
        }
      ],
      "dest": "https://hotmessldn.com/$1",
      "status": 301
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(self), geolocation=(self), microphone=()",
        "Strict-Transport-Security": "max-age=31536000; includeSubDomains; preload",
        "Content-Security-Policy": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://*.stripe.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://w.soundcloud.com https://vercel.live https://telegram.org https://*.telegram.org; script-src-elem 'self' 'unsafe-inline' https://js.stripe.com https://w.soundcloud.com https://vercel.live https://telegram.org https://*.telegram.org; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.soundcloud.com https://w.soundcloud.com https://*.stripe.com https://vercel.live wss://vercel.live wss://*.pusher.com https://*.pusher.com https://*.ingest.sentry.io https://*.ingest.de.sentry.io https://accounts.google.com; frame-src https://w.soundcloud.com https://js.stripe.com https://hooks.stripe.com https://oauth.telegram.org https://vercel.live https://accounts.google.com; media-src 'self' https: blob:; worker-src 'self' blob:"
      },
      "continue": true
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(?!assets/|data/).*",
      "dest": "/index.html"
    }
  ]
}